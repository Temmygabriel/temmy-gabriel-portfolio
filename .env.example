# ─────────────────────────────────────────────────────────────
# TEMMY GABRIEL PORTFOLIO — Environment Variables
# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local to GitHub.
# ─────────────────────────────────────────────────────────────

# Admin password hash
# Generate with: node -e "const b=require('bcryptjs');b.hash('YOUR_PASSWORD',10).then(console.log)"
# Example: if your password is "myS3cur3pass", run the command above to get the hash
ADMIN_PASSWORD=

# Iron Session secret — must be at least 32 random characters
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=

# GitHub Personal Access Token
# Go to: https://github.com/settings/tokens → Generate new token (classic)
# Required scopes: repo (full control of private repositories)
# The token lets the admin panel commit changes to your repo automatically
GITHUB_TOKEN=

# Your GitHub username (e.g. Temmygabriel)
GITHUB_OWNER=Temmygabriel

# Your GitHub repository name (e.g. temmy-gabriel-portfolio)
GITHUB_REPO=temmy-gabriel-portfolio
